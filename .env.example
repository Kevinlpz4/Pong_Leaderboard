# ============================================
# Configuración de Pong Leaderboard
# ============================================
# Copiá este archivo a .env y modificá los valores

# ====================
# API Settings
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ====================
# Database
# ====================
DATABASE_URL=sqlite:///./scores.db

# ====================
# Game Settings
# ====================
GAME_TITLE=Pong
GAME_FPS=100
BALL_SPEED_INCREMENT=1.05
BALL_MAX_SPEED=40
POINTS_PER_GOAL=100

# ====================
# API Client (desde el juego)
# ====================
API_BASE_URL=http://localhost:8000
API_TIMEOUT=5
